{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total Predictions",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(predictions_total)",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "blue", "value": null }] } }
      }
    },
    {
      "title": "Frauds Detected",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(predictions_total{result=\"fraud\"}) or vector(0)",
          "legendFormat": "Frauds"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
      }
    },
    {
      "title": "Avg Latency (ms)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(prediction_latency_seconds_sum[5m]) / rate(prediction_latency_seconds_count[5m]) * 1000",
          "legendFormat": "Avg Latency"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] } }
      }
    },
    {
      "title": "Avg Confidence",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "rate(prediction_confidence_sum[5m]) / rate(prediction_confidence_count[5m])",
          "legendFormat": "Confidence"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 0.8 }] } }
      }
    },
    {
      "title": "Predictions per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "rate(predictions_total[1m])",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Prediction Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(prediction_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(prediction_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "title": "Predictions by Transaction Type",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum by (tx_type) (predictions_by_type_total) or sum by (tx_type) (predictions_by_type)",
          "legendFormat": "{{tx_type}}"
        }
      ]
    },
    {
      "title": "Fraud vs Legit (cumulative)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "predictions_total{result=\"fraud\"} or vector(0)",
          "legendFormat": "Fraud"
        },
        {
          "expr": "predictions_total{result=\"legit\"}",
          "legendFormat": "Legit"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["fraud-detection", "mlops"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Fraud Detection - API Monitoring",
  "uid": "fraud-detection-api",
  "version": 1
}
